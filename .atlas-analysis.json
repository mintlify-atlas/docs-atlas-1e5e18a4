  "keyFeatures": [
    "50+ accessible React components built on Ark UI headless primitives",
    "Zero-runtime styling via Panda CSS with static, type-safe styles at build time",
    "Fully themeable with design tokens, accent colors, gray scales, and border radius options",
    "Dark mode support via semantic tokens that adapt automatically",
    "Composable factory system (fidely factory) to create styled Ark UI components",
    "Panda CSS preset (@fidely-ui/panda-preset) usable independently of React components",
    "Multiple framework guides: Next.js, Vite, React Router, Laravel",
    "Custom color palette support using Radix Colors-based createColorTokens utility"
  ],
  "publicApiSurface": [
    "@fidely-ui/react — main package exporting all components",
    "@fidely-ui/panda-preset — Panda CSS preset with fidelyPreset(options)",
    "fidelyPreset({ accentColor, grayColor, rounded }) — configure theme preset",
    "fidely factory — fidely('button') / fidely.button for styled Ark UI components",
    "makeStyleContext — utility for slot recipe style context",
    "Button, IconButton, Input, Textarea, Select, Checkbox, Switch, PinInput, PasswordInput, Combobox, Field, CommandInput",
    "Dialog, Popover, HoverCard, Menu, Tabs, Accordion, Clipboard",
    "Card, Table, Avatar, AvatarGroup, Persona, Profile, Image, Icon, Skeleton, Spinner, Marquee, Badge",
    "Box, Center, Flex, Grid, Stack, Wrap, Divider, Paper, Text, Heading, Em, Span, Kbd",
    "ClientOnly, Portal, LocaleProvider, DownloadTrigger, Format utilities",
    "createColorTokens(name, light, dark) — custom color palette utility from @fidely-ui/panda-preset/utils",
    "Exported anatomy keys from @fidely-ui/react/anatomy for slot recipe customization"
  ]
